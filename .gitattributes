# Maven wrapper scripts
/mvnw text eol=lf
/mvnw.cmd text eol=crlf
.mvn/wrapper/maven-wrapper.properties text eol=lf
.mvn/wrapper/maven-wrapper.jar binary

# Java source files
*.java text eol=lf

# XML, properties, JSON, YAML
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# SQL scripts
*.sql text eol=lf

# Markdown, documentation
*.md text eol=lf

# Ignore binaries
*.jar binary
*.exe binary
*.dll binary
*.db binary
